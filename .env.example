# Agenda Sobral - Configuração de Ambiente

# ============================================================
# SUPABASE (Opcional - Easypanel Self-Hosted)
# ============================================================
# Se configurado, o app usará Supabase como backend.
# Caso contrário, usa localStorage (mode offline-first).

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-aqui
VITE_SUPABASE_SERVICE_ROLE_KEY=sua-chave-admin-aqui

# ============================================================
# APP CONFIGURATION
# ============================================================

VITE_APP_NAME=Agenda Sobral
VITE_APP_VERSION=1.0.0
VITE_LOCALE=pt-BR

# ============================================================
# FEATURE FLAGS
# ============================================================

# Usar Supabase como backend (true/false)
VITE_USE_SUPABASE=false

# Ativar modo desenvolvimento
VITE_DEBUG=false

# ============================================================
# NOTAS DE SEGURANÇA
# ============================================================
# NUNCA comita este arquivo com valores reais!
# Sempre use variáveis de ambiente do sistema.
# As chaves expostas devem ser rotacionadas imediatamente.
